{
  "manifest_version": 3,
  "name": "CableSnap — Empleado",
  "version": "1.0",
  "description": "Captura y envía fotos de cortes de cable a la cajera",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["http://*/*", "https://*/*"]
}